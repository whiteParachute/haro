{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "paths": {
      "@haro/channel": [
        "../channel/dist/index.d.ts"
      ],
      "@haro/skills": [
        "../skills/dist/index.d.ts"
      ]
    }
