{
  "name": "@haro/provider-codex",
  "version": "0.1.0",
  "description": "Haro Codex Provider — wraps @openai/codex-sdk (FEAT-003)",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:live": "vitest run --mode live --testNamePattern @live"
  },
  "dependencies": {
    "@haro/core": "workspace:*",
    "@openai/codex-sdk": "^0.125.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
