{
  "name": "haro",
  "private": true,
  "version": "0.1.0",
  "description": "Haro — self-evolving multi-agent platform (monorepo root)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "clean": "pnpm -r --filter \"./packages/*\" run clean",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"packages/*/src/**/*.ts\" \"scripts/**/*.ts\"",
    "init-db": "tsx scripts/init-db.ts",
    "smoke": "node --import tsx scripts/smoke.ts",
    "haro": "node packages/cli/bin/haro.js",
    "dev:cli": "node packages/cli/bin/haro.js",
    "setup": "node packages/cli/bin/haro.js setup",
    "dev:web": "concurrently -k -n web,api \"pnpm -F @haro/web dev --host 127.0.0.1\" \"pnpm -F @haro/cli build && pnpm -F @haro/cli exec node ./bin/haro.js web --port 3456 --host 127.0.0.1\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
